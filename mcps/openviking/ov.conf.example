{
  "storage": {
    "workspace": "~/.openviking/data",
    "vectordb": {
      "name": "context",
      "backend": "local",
      "project": "default"
    },
    "agfs": {
      "port": 1833,
      "log_level": "warn",
      "backend": "local",
      "timeout": 10,
      "retry_times": 3
    }
  },

  "embedding": {
    "dense": {
      "provider": "openai",
      "model": "jinaai/jina-embeddings-v2-base-en",
      "api_key": "local",
      "api_base": "http://localhost:8081/v1",
      "dimension": 768
    }
  },

  "vlm": {
    "provider": "litellm",
    "model": "{OPENVIKING_VLM_MODEL}",
    "api_key": "{OPENVIKING_VLM_API_KEY}",
    "temperature": 0.0,
    "max_retries": 2,
    "thinking": false
  },

  "auto_generate_l0": true,
  "auto_generate_l1": true,
  "default_search_mode": "thinking",
  "default_search_limit": 3,
  "enable_memory_decay": true,

  "log": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "output": "stdout"
  }
}
