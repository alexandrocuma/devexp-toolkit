# mcps/.env — API keys for MCP servers that require external services
# Copy this file to mcps/.env and fill in your values.
# This file is gitignored. Never commit mcps/.env.

# ── OpenViking ────────────────────────────────────────────────────────────────
# OpenViking uses a local Jina embedding model via Docker (no key needed).
# Only a VLM API key is required for RAG answer generation.
#
# Choose ONE provider below and uncomment its lines:

# Anthropic (Claude) — via litellm
# OPENVIKING_VLM_API_KEY=sk-ant-...
# OPENVIKING_VLM_MODEL=claude-sonnet-4-6

# OpenAI
# OPENVIKING_VLM_API_KEY=sk-...
# OPENVIKING_VLM_MODEL=gpt-4o

# DeepSeek — via litellm
# OPENVIKING_VLM_API_KEY=sk-...
# OPENVIKING_VLM_MODEL=deepseek/deepseek-chat

# Kimi (Moonshot) — via litellm
# OPENVIKING_VLM_API_KEY=sk-...
# OPENVIKING_VLM_MODEL=moonshot/kimi-k2.5
